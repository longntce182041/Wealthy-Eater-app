# ── Server ────────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ── Database ──────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017/wealthy_eater

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate strong secrets: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=replace-with-a-strong-random-secret
JWT_REFRESH_SECRET=replace-with-a-different-strong-random-secret
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins. Leave empty to allow only localhost.
# Use * to allow all (NOT recommended for production).
CORS_ORIGIN=

# ── Google OAuth ──────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# ── AI Service ───────────────────────────────────────────────────────────────
AI_SERVICE_WEBHOOK_URL=http://127.0.0.1:5678/webhook/meal-plan-generation

# ── PayOS ─────────────────────────────────────────────────────────────────────
PAYOS_CLIENT_ID=
PAYOS_API_KEY=
PAYOS_CHECKSUM_KEY=
111